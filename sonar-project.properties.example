# ===========================================
# SonarQube Configuration - EXAMPLE FILE
# Copy this file to sonar-project.properties
# and fill in your actual values.
# sonar-project.properties is git-ignored.
# ===========================================

sonar.projectKey=YOUR_PROJECT_KEY
sonar.projectName=YOUR_PROJECT_NAME
sonar.projectVersion=1.0

# SonarQube server URL
sonar.host.url=http://localhost:9000

# Authentication token (generate one in SonarQube > My Account > Security)
sonar.token=YOUR_SONARQUBE_TOKEN

# Sources & exclusions
sonar.sources=src
# Exclude test files, build artifacts, and Tailwind v4 CSS files that use
# @source / @custom-variant at-rules not recognized by SonarQube (false positives)
sonar.exclusions=**/node_modules/**,**/dist/**,**/*.test.ts,**/*.test.tsx,**/*.spec.ts,**/coverage/**,**/styles/tailwind.css,**/styles/theme.css

# Language
sonar.language=ts
